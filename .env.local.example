# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# .env.local NUNCA é commitado (ver .gitignore).

# --- Anthropic (IA) ---
# Usada SOMENTE em Route Handlers do servidor (app/api/**). Nunca expor ao client.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# URL do projeto: Supabase Dashboard > Project Settings > Data API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key: Supabase Dashboard > Project Settings > API Keys
# Tem acesso total (bypassa RLS) — usar SOMENTE no servidor (Route Handlers),
# nunca prefixar com NEXT_PUBLIC_ e nunca expor ao client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
